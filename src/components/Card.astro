---
interface Props {
	title: string;
	meta?: string;
	tags?: string[];
	image?: string;
	imageAlt?: string;
	hoverImage?: string;
	hoverImageAlt?: string;
	links?: { label: string; href: string }[];
	href?: string;
	filterTypes?: string[];
	titleIcon?: 'steam' | 'itch';
	platformIcons?: ('windows' | 'mac' | 'browser')[];
	allRoles?: string[];
}

const {
	title,
	meta,
	tags = [],
	image,
	imageAlt = '',
	hoverImage,
	hoverImageAlt = '',
	links = [],
	href,
	filterTypes = [],
	titleIcon,
	platformIcons = [],
	allRoles = [],
} = Astro.props;
---

<article
	class:list={['card', image && 'card--with-media']}
	data-types={filterTypes.join('|')}
>
	{
		image && (
			<div class:list={['card__media', hoverImage && 'card__media--swap']}>
				{href ? (
					<a href={href} aria-label={`View ${title}`}>
						<img class="card__image card__image--splash" src={image} alt={imageAlt} loading="eager" />
						{hoverImage && (
							<img
								class="card__image card__image--hover"
								src={hoverImage}
								alt={hoverImageAlt}
								loading="eager"
								aria-hidden={hoverImageAlt ? undefined : 'true'}
							/>
						)}
					</a>
				) : (
					<>
						<img class="card__image card__image--splash" src={image} alt={imageAlt} loading="eager" />
						{hoverImage && (
							<img
								class="card__image card__image--hover"
								src={hoverImage}
								alt={hoverImageAlt}
								loading="eager"
								aria-hidden={hoverImageAlt ? undefined : 'true'}
							/>
						)}
					</>
				)}
			</div>
		)
	}
	<div class="card__body">
		<div class="card__topline">
			{meta && <div class="card__meta">{meta}</div>}
			{
				allRoles.length > 0 && (
					<div class="card__roles">
						<span class="card__roles-trigger" aria-label={`All roles for ${title}`}>
							<span>All roles</span>
							<span class="card__roles-caret" aria-hidden="true"></span>
						</span>
						<div class="card__roles-popover">
							{allRoles.map((role) => <span>{role}</span>)}
						</div>
					</div>
				)
			}
		</div>
		<h3>
			{
				href ? (
					<a class="card__title-link" href={href}>
						<span class="card__title-text">
							<span>{title}</span>
							{titleIcon === 'steam' && (
								<svg class="card__title-icon" viewBox="0 0 24 24" aria-label="Steam">
									<circle cx="12" cy="12" r="9" />
									<circle cx="15.8" cy="8.3" r="2.6" />
									<circle cx="8.2" cy="15.5" r="2.1" />
									<path d="M10 14.3l3.7-2.4" />
									<path d="M6.5 14.6l-2.8-1.1" />
								</svg>
							)}
							{titleIcon === 'itch' && (
								<svg class="card__title-icon" viewBox="0 0 24 24" aria-label="Itch.io">
									<path d="M5.4 9.2h13.2" />
									<path d="M6.6 5.2h10.8l1.2 4H5.4l1.2-4Z" />
									<path d="M7 9.2v9.6h10V9.2" />
									<path d="M9.4 12.2h5.2v3.4H9.4z" />
									<path d="M9 5.2v4" />
									<path d="M12 5.2v4" />
									<path d="M15 5.2v4" />
								</svg>
							)}
							{platformIcons.length > 0 && (
								<span class="card__title-platforms" aria-label={`${title} platforms`}>
									{platformIcons.map((platform) => (
										<>
											{platform === 'windows' && (
												<svg class="card__platform-icon" viewBox="0 0 24 24" aria-label="Windows">
													<path d="M4.5 5.6 11 4.7v6.6H4.5z" />
													<path d="M13 4.4 19.5 3.5v7.8H13z" />
													<path d="M4.5 12.7H11v6.6l-6.5-.9z" />
													<path d="M13 12.7h6.5v7.8L13 19.6z" />
												</svg>
											)}
											{platform === 'mac' && (
												<svg class="card__platform-icon" viewBox="0 0 24 24" aria-label="macOS">
													<path d="M13.2 3.7c-.6.5-.9 1.1-.9 1.9.8 0 1.5-.3 2-.9.5-.5.8-1.2.8-1.9-.8.1-1.4.4-1.9.9Z" />
													<path d="M17.1 12.7c0-1.5.8-2.7 2-3.4-.9-1.3-2.2-2.1-3.6-2.1-.8 0-1.5.3-2.1.6-.5.2-1 .4-1.4.4-.5 0-1-.2-1.5-.4-.6-.3-1.2-.6-2-.6-2.1 0-4.1 2-4.1 5.1 0 3.3 2.3 7.1 4.1 7.1.6 0 1.1-.2 1.6-.5.6-.3 1.1-.5 1.9-.5s1.3.2 1.9.5c.5.2 1 .5 1.6.5 1.4 0 2.8-2.1 3.5-3.9-1.2-.5-1.9-1.6-1.9-2.8Z" />
												</svg>
											)}
											{platform === 'browser' && (
												<svg class="card__platform-icon" viewBox="0 0 24 24" aria-label="Browser">
													<circle cx="12" cy="12" r="8" />
													<path d="M4.7 9.2h14.6" />
													<path d="M4.7 14.8h14.6" />
													<path d="M12 4c2 2.2 3 4.9 3 8s-1 5.8-3 8" />
													<path d="M12 4c-2 2.2-3 4.9-3 8s1 5.8 3 8" />
												</svg>
											)}
										</>
									))}
								</span>
							)}
						</span>
					</a>
				) : (
					<span class="card__title-text">
						<span>{title}</span>
						{titleIcon === 'steam' && (
							<svg class="card__title-icon" viewBox="0 0 24 24" aria-label="Steam">
								<circle cx="12" cy="12" r="9" />
								<circle cx="15.8" cy="8.3" r="2.6" />
								<circle cx="8.2" cy="15.5" r="2.1" />
								<path d="M10 14.3l3.7-2.4" />
								<path d="M6.5 14.6l-2.8-1.1" />
							</svg>
						)}
						{titleIcon === 'itch' && (
							<svg class="card__title-icon" viewBox="0 0 24 24" aria-label="Itch.io">
								<path d="M5.4 9.2h13.2" />
								<path d="M6.6 5.2h10.8l1.2 4H5.4l1.2-4Z" />
								<path d="M7 9.2v9.6h10V9.2" />
								<path d="M9.4 12.2h5.2v3.4H9.4z" />
								<path d="M9 5.2v4" />
								<path d="M12 5.2v4" />
								<path d="M15 5.2v4" />
							</svg>
						)}
						{platformIcons.length > 0 && (
							<span class="card__title-platforms" aria-label={`${title} platforms`}>
								{platformIcons.map((platform) => (
									<>
										{platform === 'windows' && (
											<svg class="card__platform-icon" viewBox="0 0 24 24" aria-label="Windows">
												<path d="M4.5 5.6 11 4.7v6.6H4.5z" />
												<path d="M13 4.4 19.5 3.5v7.8H13z" />
												<path d="M4.5 12.7H11v6.6l-6.5-.9z" />
												<path d="M13 12.7h6.5v7.8L13 19.6z" />
											</svg>
										)}
										{platform === 'mac' && (
											<svg class="card__platform-icon" viewBox="0 0 24 24" aria-label="macOS">
												<path d="M13.2 3.7c-.6.5-.9 1.1-.9 1.9.8 0 1.5-.3 2-.9.5-.5.8-1.2.8-1.9-.8.1-1.4.4-1.9.9Z" />
												<path d="M17.1 12.7c0-1.5.8-2.7 2-3.4-.9-1.3-2.2-2.1-3.6-2.1-.8 0-1.5.3-2.1.6-.5.2-1 .4-1.4.4-.5 0-1-.2-1.5-.4-.6-.3-1.2-.6-2-.6-2.1 0-4.1 2-4.1 5.1 0 3.3 2.3 7.1 4.1 7.1.6 0 1.1-.2 1.6-.5.6-.3 1.1-.5 1.9-.5s1.3.2 1.9.5c.5.2 1 .5 1.6.5 1.4 0 2.8-2.1 3.5-3.9-1.2-.5-1.9-1.6-1.9-2.8Z" />
											</svg>
										)}
										{platform === 'browser' && (
											<svg class="card__platform-icon" viewBox="0 0 24 24" aria-label="Browser">
												<circle cx="12" cy="12" r="8" />
												<path d="M4.7 9.2h14.6" />
												<path d="M4.7 14.8h14.6" />
												<path d="M12 4c2 2.2 3 4.9 3 8s-1 5.8-3 8" />
												<path d="M12 4c-2 2.2-3 4.9-3 8s1 5.8 3 8" />
											</svg>
										)}
									</>
								))}
							</span>
						)}
					</span>
				)
			}
		</h3>
		<div>
			<slot />
		</div>
		{
			tags.length > 0 && (
				<div class="card__tags" aria-label={`${title} tags`}>
					{tags.map((tag) => <span class="tag">{tag}</span>)}
				</div>
			)
		}
		{
			links.length > 0 && (
				<div class="card__actions" aria-label={`${title} links`}>
					{links.map((link) => (
						<a href={link.href}>{link.label}</a>
					))}
				</div>
			)
		}
	</div>
</article>
