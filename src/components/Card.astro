---
interface Props {
	title: string;
	meta?: string;
	tags?: string[];
	image?: string;
	imageAlt?: string;
	links?: { label: string; href: string }[];
	href?: string;
	filterTypes?: string[];
}

const {
	title,
	meta,
	tags = [],
	image,
	imageAlt = '',
	links = [],
	href,
	filterTypes = [],
} = Astro.props;
---

<article
	class:list={['card', image && 'card--with-media']}
	data-types={filterTypes.join('|')}
>
	{
		image && (
			<div class="card__media">
				{href ? (
					<a href={href} aria-label={`View ${title}`}>
						<img src={image} alt={imageAlt} loading="eager" />
					</a>
				) : (
					<img src={image} alt={imageAlt} loading="eager" />
				)}
			</div>
		)
	}
	<div class="card__body">
		{meta && <div class="card__meta">{meta}</div>}
		<h3>{href ? <a class="card__title-link" href={href}>{title}</a> : title}</h3>
		<div>
			<slot />
		</div>
		{
			tags.length > 0 && (
				<div class="card__tags" aria-label={`${title} tags`}>
					{tags.map((tag) => <span class="tag">{tag}</span>)}
				</div>
			)
		}
		{
			links.length > 0 && (
				<div class="card__actions" aria-label={`${title} links`}>
					{links.map((link) => (
						<a href={link.href}>{link.label}</a>
					))}
				</div>
			)
		}
	</div>
</article>
