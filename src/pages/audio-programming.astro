---
import ButtonLink from '../components/ButtonLink.astro';
import Card from '../components/Card.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { experiences } from '../data/experience';
import { featuredProjects } from '../data/projects';
import Layout from '../layouts/Layout.astro';

const professionalAudio = experiences.filter((experience) =>
	['Snow Day Games', 'Activision / Raven Software', 'Serious Point Games'].includes(experience.company),
);

const audioFocusAreas = [
	{
		title: 'Runtime Audio Systems',
		meta: 'Gameplay-responsive implementation',
		description:
			'Event routing, state-driven ambience, combat feedback, interactables, UI audio, room-aware transitions, and gameplay-readable feedback.',
		tags: ['Events', 'States', 'Feedback'],
	},
	{
		title: 'DSP / Signal Work',
		meta: 'Sample-level systems',
		description:
			'Filtering, delay lines, feedback, bit-depth reduction, gain shaping, smoothing, and gameplay-controlled audio parameters.',
		tags: ['DSP', 'C++', 'Real-Time'],
	},
	{
		title: 'Middleware Integration',
		meta: 'Designer-facing pipelines',
		description:
			'Wwise and FMOD implementation, events, states, switches, RTPCs, Unity integration, iteration workflows, and debugging paths.',
		tags: ['Wwise', 'FMOD', 'Unity'],
	},
	{
		title: 'Production Tools',
		meta: 'Workflow and maintainability',
		description:
			'Audio tools, asset processing, debug visibility, tunable systems, and implementation patterns that support production teams.',
		tags: ['Tools', '.NET/WPF', 'Pipelines'],
	},
];
---

<Layout
	title="Audio Programming - Shawn Guo"
	description="Game audio systems, DSP, Wwise implementation, and technical audio engineering."
>
	<section class="hero hero--compact">
		<div class="container">
			<p class="eyebrow">Audio Programming</p>
			<h1>DSP, middleware, gameplay state.</h1>
			<p class="lede">
				I build audio systems where engineering, implementation, and player feedback meet:
				low-level C/C++ runtime work, Wwise-driven gameplay audio, custom DSP, and production
				tools for audio teams.
			</p>
			<div class="cluster">
				<ButtonLink href="/projects">View Projects</ButtonLink>
				<ButtonLink href={`mailto:shawnguo.dev@gmail.com`} variant="secondary">Contact</ButtonLink>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<SectionHeader
				eyebrow="Professional audio engineering"
				title="Production work across AAA, indie, and spatial audio."
				lede="These cards are intentionally NDA-safe and focused on the engineering shape of the work: runtime systems, tools, implementation, debugging, and production collaboration."
			/>
			<div class="grid">
				{professionalAudio.map((experience) => (
					<Card
						title={experience.company}
						meta={`${experience.role} / ${experience.timeframe}`}
						tags={experience.tags}
						image={experience.image}
						imageAlt={experience.imageAlt}
					>
						<p>{experience.description}</p>
					</Card>
				))}
			</div>
		</div>
	</section>

	<section class="section dark">
		<div class="container split">
			<SectionHeader
				eyebrow="Audio focus"
				title="Not just implementation. Systems that respond."
				lede="The strongest through-line is gameplay-state-driven audio: systems that react to level context, player action, designer-authored states, and runtime constraints."
			/>
			<div class="timeline">
				{audioFocusAreas.map((area) => (
					<Card title={area.title} meta={area.meta} tags={area.tags}>
						<p>{area.description}</p>
					</Card>
				))}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<SectionHeader
				eyebrow="Featured audio work"
				title="Projects that show the range."
				lede="This section will eventually carry the strongest demo links and media. For now, it establishes the audio-programming story across middleware, DSP, and feedback systems."
			/>
			<div class="grid">
				{featuredProjects.map((project) => (
					<Card title={project.title} meta={project.meta} tags={project.tags}>
						<p>{project.description}</p>
					</Card>
				))}
			</div>
		</div>
	</section>

	<section class="section tight">
		<div class="container split">
			<div class="callout">
				<p class="eyebrow">Technical signal</p>
				<h2>Audio as software engineering.</h2>
				<p>
					The page should make it clear that the specialization includes code, architecture,
					debugging, performance, tooling, implementation, and taste.
				</p>
			</div>
			<div class="card">
				<div class="card__body">
					<h3>Current emphasis</h3>
					<ul class="feature-list">
						<li>C/C++ runtime audio systems and APIs in production game environments.</li>
						<li>Wwise-integrated Unity gameplay audio architecture for exploration and combat.</li>
						<li>Custom DSP prototypes tied directly to mechanics and narrative state.</li>
						<li>Tools and pipelines that make audio implementation easier to iterate on.</li>
					</ul>
				</div>
			</div>
		</div>
	</section>
</Layout>
