---
import Card from '../components/Card.astro';
import Layout from '../layouts/Layout.astro';

const games = [
	{
		title: 'Vesuvius',
		role: 'Co-Creator, Audio Programmer',
		allRoles: ['Co-Creator', 'Audio Programmer', 'Composer', 'Sound Designer'],
		summary: 'A 2D action platformer set within a frozen volcano where you journey through fantastical alternate realities and battle corrupted mythical beasts. The game is supported by $15k in grant funding.',
		tags: ['Wwise', 'C++', 'C#'],
		image: '/assets/my-games/vesuvius-splash.png',
		imageAlt: 'Vesuvius splash image',
		hoverImage: '/assets/my-games/vesuvius-gameplay.gif',
		hoverImageAlt: 'Vesuvius gameplay preview',
		platforms: ['windows', 'mac'],
		steam: 'https://store.steampowered.com/app/4557830/Vesuvius/',
	},
	{
		title: 'ADSOMNIA',
		role: 'Creator, Lead Programmer',
		allRoles: ['Creator', 'Lead Programmer', 'Tech Sound Designer', 'UI Designer'],
		summary: 'A surreal ad-horror game where invasive dream ads drain your Brain Oxygen. It won 2nd place at the 2026 Ctrl + Alt + DMV game jam, yay!',
		tags: ['Unity', 'C#'],
		image: '/assets/my-games/adsomnia-splash.gif',
		imageAlt: 'ADSOMNIA splash image',
		hoverImage: '/assets/my-games/adsomnia-gameplay.gif',
		hoverImageAlt: 'ADSOMNIA gameplay preview',
		platforms: ['browser'],
		itch: 'https://yeetimameme.itch.io/adsomnia',
		github: 'https://github.com/L1Ryx/CADMV-2026',
	},
	{
		title: 'Ducks Afar',
		role: 'Creator, Lead Programmer',
		allRoles: ['Creator', 'Lead Programmer', 'Producer', '2D Artist', 'UI Designer', 'Composer', 'Tech Sound Designer'],
		summary: 'A narrative adventure game in development where players manipulate hardworms, solve machine-based challenges, and save their ducks.',
		tags: ['Wwise', 'Unity', 'C#'],
		image: '/assets/my-games/ducks-afar-splash.gif',
		imageAlt: 'Ducks Afar splash image',
		hoverImage: '/assets/my-games/ducks-afar-gameplay.gif',
		hoverImageAlt: 'Ducks Afar gameplay preview',
		platforms: ['windows', 'mac'],
		itch: 'https://l1ryx.itch.io/ducks-afar',
		github: 'https://github.com/L1Ryx/Ducks-Afar',
	},
	{
		title: 'Love Language',
		role: 'Gameplay Programmer, Technical Sound Designer',
		allRoles: ['Gameplay Programmer', 'Tech Sound Designer', 'Producer'],
		summary: 'A psychological horror visual novel where your date is not quite who he seems. I led the Hopkins Game Development Society team behind the project.',
		tags: ['FMOD', 'Unity', 'C#'],
		image: '/assets/my-games/love-language-splash.gif',
		imageAlt: 'Love Language splash art',
		hoverImage: '/assets/my-games/love-language-gameplay.gif',
		hoverImageAlt: 'Love Language gameplay preview',
		platforms: ['browser'],
		itch: 'https://hopkins-game-dev-society.itch.io/love-language',
		github: 'https://github.com/Hopkins-Game-Dev-Society/ScreamJam2025',
	},
	{
		title: 'Negative Space',
		role: 'Creator, Lead Programmer',
		allRoles: ['Creator', 'Lead Programmer', 'Sound Designer'],
		summary: 'A short first-person game set in darkness, where players use paint and spatial audio to locate hidden beacons.',
		tags: ['C++', 'raylib', 'Dear ImGui'],
		image: '/assets/my-games/negative-space-engine-splash.png',
		imageAlt: 'Negative Space splash image',
		hoverImage: '/assets/my-games/negative-space-gameplay.gif',
		hoverImageAlt: 'Negative Space gameplay preview',
		platforms: ['windows', 'mac'],
		itch: 'https://l1ryx.itch.io/negative-space',
		github: 'https://github.com/L1Ryx/Negative-Space',
	},
	{
		title: 'Deja You',
		role: 'Audio Programmer, Technical Sound Designer',
		summary: 'A 2D time-loop platformer where each rewind creates a replayed version of the player, turning past lives into puzzle-solving partners.',
		tags: ['Unity', 'C#', 'C++', 'DSP'],
		image: '/assets/my-games/deja-you-splash.png',
		imageAlt: 'Deja You splash image',
		hoverImage: '/assets/my-games/deja-you-gameplay.gif',
		hoverImageAlt: 'Deja You gameplay preview',
		platforms: ['windows', 'mac'],
		itch: 'https://johnnieshen.itch.io/deja-you',
		github: 'https://github.com/JohnnieShen/GMTK-HGDS',
	},
	{
		title: 'Aftertaste',
		role: 'Technical Sound Designer',
		summary: 'A 2.5D indie platformer where Tami, the tongue of a burned-out chef, rediscovers lost taste through surreal adventure and puzzles.',
		tags: ['Wwise', 'Unity', 'C#'],
		image: '/assets/my-games/aftertaste-splash.png',
		imageAlt: 'Aftertaste splash image',
		hoverImage: '/assets/my-games/aftertaste-gameplay.gif',
		hoverImageAlt: 'Aftertaste gameplay preview',
		platforms: ['windows', 'mac'],
		steam: 'https://store.steampowered.com/app/4440750/Aftertaste/',
	},
];

const gameLinks = (game) => [
	...(game.github ? [{ label: 'GitHub', href: game.github }] : []),
	...(game.itch ? [{ label: 'Itch.io', href: game.itch }] : []),
	...(game.steam ? [{ label: 'Steam', href: game.steam }] : []),
];
---

<Layout
	title="Games - Shawn Guo"
	description="Games by Shawn Guo and collaborators."
>
	<section class="projects-hero">
		<div class="container projects-hero__inner">
			<p class="eyebrow">games.md</p>
			<h1>Games</h1>
		</div>
	</section>

	<section class="section projects-section">
		<div class="container">
			<div class="project-card-grid">
				{games.map((game) => (
					<Card
						title={game.title}
						meta={game.role}
						tags={game.tags}
						image={game.image}
						imageAlt={game.imageAlt}
						hoverImage={game.hoverImage}
						hoverImageAlt={game.hoverImageAlt}
						href={game.itch ?? game.steam ?? game.github}
						links={gameLinks(game)}
						titleIcon={game.steam ? 'steam' : 'itch'}
						platformIcons={game.platforms}
						allRoles={game.allRoles}
					>
						<p>{game.summary}</p>
					</Card>
				))}
			</div>
		</div>
	</section>
</Layout>
