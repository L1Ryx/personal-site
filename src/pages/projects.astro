---
import Card from '../components/Card.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { featuredProjects } from '../data/projects';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Projects - Shawn Guo"
	description="Selected game, audio programming, and interactive software projects by Shawn Guo."
>
	<section class="section">
		<div class="container">
			<SectionHeader
				eyebrow="Projects"
				title="A focused gallery is coming next."
				lede="For the foundation pass, this route is wired up with the first reusable project cards. Later passes can add media, links, status labels, and more projects."
			/>
			<div class="grid">
				{featuredProjects.map((project) => (
					<Card title={project.title} meta={project.meta} tags={project.tags}>
						<p>{project.description}</p>
					</Card>
				))}
			</div>
		</div>
	</section>
</Layout>
