---
import ButtonLink from '../components/ButtonLink.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Software Engineering - Shawn Guo"
	description="Production C/C++, Unity systems, interactive web tools, and real-time software."
>
	<section class="hero hero--compact">
		<div class="container">
			<p class="eyebrow">Software Engineering</p>
			<h1>Games, tools, real-time systems.</h1>
			<p class="lede">
				This page will frame the same background for broader SWE, tools, gameplay, and interactive
				software roles. The next pass will turn the professional experience into recruiter-ready
				engineering cards.
			</p>
			<div class="cluster">
				<ButtonLink href="/audio-programming">Audio Programming</ButtonLink>
				<ButtonLink href="/projects" variant="secondary">Projects</ButtonLink>
			</div>
		</div>
	</section>
</Layout>
